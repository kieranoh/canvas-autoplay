{
  "manifest_version": 3,
  "name": "SKKU Lecture Runner",
  "description": "Finds Canvas SKKU lecture items and moves through them one by one.",
  "version": "1.1.1",
  "permissions": ["activeTab", "storage", "scripting", "debugger", "tabs"],
  "host_permissions": [
    "https://canvas.skku.edu/*",
    "https://*.skku.edu/*",
    "https://*.learningx.kr/*",
    "https://*.kaltura.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "SKKU Lecture Runner",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://canvas.skku.edu/*",
        "https://*.skku.edu/*",
        "https://*.learningx.kr/*",
        "https://*.kaltura.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
